# ============================================
# SUPABASE Configuration
# ============================================
# Get these from your Supabase project Settings > API
SUPABASE_URL=https://your-project.supabase.co
# IMPORTANT: Use SERVICE_ROLE key, NOT anon key
# Service role key has elevated privileges for admin operations
SUPABASE_SERVICE_ROLE=your-service-role-key

# ============================================
# ADMIN AUTHENTICATION
# ============================================
# ADMIN_PASS_HASH: Scrypt-hashed password (DO NOT store plaintext!)
# For password "websitepass123!", the hash is:
# scrypt:0921de9a048ecd4efebdf9da:tfaqarpFMyihHc5iFiRyWMwtHWzmaOEmCfHhevj4piHHl6if1Y3LYsLI/kKIQV2aHxOeO+kefT+blbGlarTjAA==
# 
# To generate a hash for a different password, run (locally):
#   node -e "const crypto = require('crypto'); const pwd='yourpassword'; const salt = crypto.randomBytes(16).toString('hex'); const hash = crypto.createHmac('sha256', salt).update(pwd).digest('base64'); console.log('scrypt:' + salt + ':' + hash);"
#
ADMIN_PASS_HASH=scrypt:0921de9a048ecd4efebdf9da:tfaqarpFMyihHc5iFiRyWMwtHWzmaOEmCfHhevj4piHHl6if1Y3LYsLI/kKIQV2aHxOeO+kefT+blbGlarTjAA==

# JWT Secret: Long random string (used to sign admin login tokens)
# Generate: openssl rand -base64 32
# Example: JL9pwK8mN2xQ7rS+vT3uW4xY5zH6jK7lM8nO9pP0qR1sT2uV3w
ADMIN_JWT_SECRET=replace_with_a_long_random_secret_generate_one

# Server Port
PORT=8787

# CORS: Comma-separated list of allowed origins
# For local development: http://localhost:5173,http://127.0.0.1:5173
# For production: https://Aishwaryfilms.github.io
ADMIN_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,https://Aishwaryfilms.github.io

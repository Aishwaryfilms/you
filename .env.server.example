# Supabase (service role) - required for admin routes
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE=your-service-role-key

# Admin login (server)
ADMIN_PASS_HASH=scrypt:your_salt_hex:your_hash_base64
# or legacy password (not recommended)
ADMIN_PASS=
ADMIN_JWT_SECRET=replace_with_a_long_random_secret
ADMIN_API_PORT=8787
ADMIN_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
